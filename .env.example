# Plantilla de variables de entorno para desarrollo local
# Copia este archivo a .env y ajusta los valores según tu entorno

# Puerto local del BFF
SERVER_PORT=8080

# URL base del backend Functions
FUNCTIONS_BASE_URL=https://your-functions-app.azurewebsites.net/api

# URL completa del publisher de Event Grid (incluye ?code=...)
EVENT_PUBLISHER_URL=https://your-publisher-function.azurewebsites.net/api/MessageQueue-biblioteca?code=YOUR_FUNCTION_KEY
